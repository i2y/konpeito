# KUI DSL — type definitions for the declarative UI functions
#
# These are top-level functions (module TopLevel) since they're
# meant to be called directly from user code.

module TopLevel
  # Lifecycle
  def kui_init: (String title, Integer w, Integer h) -> Integer
  def kui_destroy: () -> Integer
  def kui_begin_frame: () -> Integer
  def kui_end_frame: () -> Integer
  def kui_running: () -> Integer

  # Layout containers
  def vpanel: (?pad: Integer, ?gap: Integer) { () -> void } -> Integer
  def hpanel: (?pad: Integer, ?gap: Integer) { () -> void } -> Integer
  def fixed_panel: (Integer w, Integer h, ?pad: Integer) { () -> void } -> Integer
  def cpanel: (?pad: Integer, ?gap: Integer) { () -> void } -> Integer
  def scroll_panel: (?pad: Integer, ?gap: Integer) { () -> void } -> Integer

  # Text
  def label: (String text, ?size: Integer, ?r: Integer, ?g: Integer, ?b: Integer) -> Integer
  def label_num: (Integer value, ?size: Integer, ?r: Integer, ?g: Integer, ?b: Integer) -> Integer

  # Interactive
  def button: (String text, ?size: Integer) { () -> void } -> Integer
  def menu_item: (String text, Integer index, Integer cursor, ?size: Integer) -> Integer

  # Decoration
  def spacer: () -> Integer
  def divider: (?r: Integer, ?g: Integer, ?b: Integer) -> Integer
  def progress_bar: (Integer value, Integer max, Integer w, Integer h, ?r: Integer, ?g: Integer, ?b: Integer) -> Integer

  # Styling
  def kui_bg: (Integer r, Integer g, Integer b) -> Integer
  def kui_border: (Integer r, Integer g, Integer b) -> Integer

  # Styled containers
  def card: (?pad: Integer, ?gap: Integer) { () -> void } -> Integer
  def header: (?pad: Integer) { () -> void } -> Integer
  def footer: (?pad: Integer) { () -> void } -> Integer
  def sidebar: (Integer w, ?pad: Integer, ?gap: Integer) { () -> void } -> Integer

  # Convenience
  def kui_load_font: (String path, Integer size) -> Integer
  def kui_key_pressed: () -> Integer
  def kui_char_pressed: () -> Integer
  def kui_mod_pressed: () -> Integer

  # Theme
  def kui_theme_dark: () -> Integer
  def kui_theme_light: () -> Integer
  def kui_reset_ids: () -> Integer
  def kui_auto_id: () -> Integer

  # Interactive (Extended)
  def checkbox: (String text, Integer checked, ?size: Integer) { () -> void } -> Integer
  def radio: (String text, Integer index, Integer selected, ?size: Integer) { () -> void } -> Integer
  def toggle: (String text, Integer on, ?size: Integer) { () -> void } -> Integer

  # Spinner
  def spinner: (?size: Integer) -> Integer

  # Text Input
  def text_input: (Integer buf_id, ?w: Integer, ?size: Integer) -> Integer
  def kui_textbuf_clear: (Integer buf_id) -> Integer
  def kui_textbuf_len: (Integer buf_id) -> Integer
  def kui_textbuf_copy: (Integer dst, Integer src) -> Integer
  def kui_textbuf_render: (Integer buf_id, ?size: Integer, ?r: Integer, ?g: Integer, ?b: Integer) -> Integer

  # Selectable List
  def selectable_list: (Integer selected, Integer count, ?visible: Integer) { () -> void } -> Integer
  def list_item: (String text, Integer index, Integer selected, ?size: Integer) { () -> void } -> Integer

  # Table
  def table_header: (?pad: Integer) { () -> void } -> Integer
  def table_row: (Integer row_index, ?pad: Integer) { () -> void } -> Integer
  def table_cell: (Integer w, ?pad: Integer) { () -> void } -> Integer

  # Modal
  def modal: (Integer w, Integer h, ?pad: Integer, ?gap: Integer) { () -> void } -> Integer

  # Tabs
  def tab_bar: (Integer active) { () -> void } -> Integer
  def tab_button: (String text, Integer index, Integer active, ?size: Integer) { () -> void } -> Integer
  def tab_content: (?pad: Integer, ?gap: Integer) { () -> void } -> Integer

  # Status Bar
  def status_bar: (?pad: Integer) { () -> void } -> Integer
  def status_left: () { () -> void } -> Integer
  def status_center: () { () -> void } -> Integer
  def status_right: () { () -> void } -> Integer

  # Badge / Chip / Tag
  def badge: (String text, ?size: Integer, ?r: Integer, ?g: Integer, ?b: Integer) -> Integer

  # Avatar
  def avatar: (String text, ?size: Integer, ?r: Integer, ?g: Integer, ?b: Integer) -> Integer

  # Progress Steps
  def progress_steps: (Integer current, Integer total, ?size: Integer) -> Integer

  # Number Stepper
  def number_stepper: (Integer value, Integer min, Integer max, ?size: Integer) { (Integer) -> void } -> Integer

  # Search Bar
  def search_bar: (Integer buf_id, ?w: Integer, ?size: Integer) -> Integer

  # Segmented Control
  def segmented_control: (Integer active) { () -> void } -> Integer
  def segment_button: (String text, Integer index, Integer active, ?size: Integer) { () -> void } -> Integer

  # Accordion
  def accordion: (String title, Integer open, ?size: Integer) { (Symbol) -> void } -> Integer

  # Alert / Confirm Dialog
  def alert_dialog: (String title, String message, ?w: Integer, ?h: Integer) { () -> void } -> Integer
  def confirm_dialog: (String title, String message, ?w: Integer, ?h: Integer) { (Symbol) -> void } -> Integer

  # Dropdown
  def dropdown: (String selected_text, ?size: Integer) { () -> void } -> Integer
  def dropdown_item: (String text, ?size: Integer) { () -> void } -> Integer

  # Tooltip
  def with_tooltip: (String hint_text, ?size: Integer) { () -> void } -> Integer

  # Toast
  def kui_show_toast: (Integer slot, ?duration: Integer, ?type: Integer) -> Integer
  def kui_toast_active: (Integer slot) -> Integer
  def kui_dismiss_toast: (Integer slot) -> Integer
  def toast: (Integer slot, String message, ?size: Integer) -> Integer
  def toast_stack: () { () -> void } -> Integer

  # Context Menu
  def context_menu: (Integer visible, ?w: Integer) { () -> void } -> Integer

  # Slider
  def slider: (Integer value, Integer min, Integer max, ?w: Integer, ?size: Integer) { (Integer) -> void } -> Integer

  # Textarea
  def textarea: (Integer first_buf_id, Integer active_line, ?lines: Integer, ?w: Integer, ?size: Integer) { (Integer) -> void } -> Integer

  # Switch
  def switch: (String text, Integer on, ?size: Integer) { () -> void } -> Integer

  # Rating
  def rating: (Integer value, Integer max, ?size: Integer) { (Integer) -> void } -> Integer

  # Color Picker
  def color_picker: (Integer r, Integer g, Integer b, ?w: Integer) { (Integer, Integer) -> void } -> Integer

  # Date Picker
  def date_picker: (Integer year, Integer month, Integer day) { (Integer, Integer) -> void } -> Integer

  # ── Phase 4: Layout Widgets ──

  # Grid
  def grid_row: (?gap: Integer) { () -> void } -> Integer
  def grid_item: (Integer w, Integer cols, ?span: Integer, ?gap: Integer) { () -> void } -> Integer

  # ZStack
  def zstack: () { () -> void } -> Integer
  def zstack_layer: (?z: Integer) { () -> void } -> Integer

  # Scaffold
  def scaffold: (?title: String, ?size: Integer) { (Symbol) -> void } -> Integer

  # Aspect Ratio
  def aspect_panel: (Integer w, Integer ratio_h) { () -> void } -> Integer

  # Horizontal Scroll
  def scroll_h_panel: (?pad: Integer, ?gap: Integer) { () -> void } -> Integer

  # Wrap Panel
  def wrap_panel: (Integer container_w, Integer item_w, ?gap: Integer) { (Integer) -> void } -> Integer
  def wrap_row: (?gap: Integer) { () -> void } -> Integer

  # ── Phase 5: Navigation ──

  # Nav State
  def kui_nav_push: (Integer page_id) -> Integer
  def kui_nav_pop: () -> Integer
  def kui_nav_current: () -> Integer
  def kui_nav_depth: () -> Integer

  # Nav Bar
  def nav_bar: (String title, ?size: Integer) { () -> void } -> Integer

  # Bottom Nav
  def bottom_nav: (Integer active) { () -> void } -> Integer
  def bottom_nav_item: (String text, Integer index, Integer active, ?size: Integer) { () -> void } -> Integer

  # Drawer
  def drawer: (Integer open, ?w: Integer, ?pad: Integer, ?gap: Integer) { () -> void } -> Integer

  # Bottom Sheet
  def bottom_sheet: (Integer open, ?h: Integer, ?pad: Integer, ?gap: Integer) { () -> void } -> Integer

  # ── Phase 6: Data Display ──

  # List Section
  def list_section: (String title, ?size: Integer) -> Integer

  # Sortable Header
  def sortable_header: (String text, Integer w, Integer col, Integer sort_col, Integer dir, ?size: Integer) { () -> void } -> Integer

  # Carousel
  def carousel_dots: (Integer active, Integer count, ?size: Integer) -> Integer

  # Timeline
  def timeline_item: (String text, Integer active, ?size: Integer) -> Integer
  def timeline_connector: () -> Integer

  # Skeleton
  def skeleton: (Integer w, Integer h) -> Integer

  # Circular Progress
  def circular_progress: (Integer value, Integer max, ?size: Integer) -> Integer

  # Image Placeholder
  def image_placeholder: (Integer texture_id, Integer w, Integer h) -> Integer
end
