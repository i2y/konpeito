  def self.color_lightgray: () -> Integer

  %a{cfunc: "konpeito_color_gray"}
  def self.color_gray: () -> Integer

  %a{cfunc: "konpeito_color_raywhite"}
  def self.color_raywhite: () -> Integer

  %a{cfunc: "konpeito_color_darkblue"}
  def self.color_darkblue: () -> Integer

  %a{cfunc: "konpeito_color_skyblue"}
  def self.color_skyblue: () -> Integer

  %a{cfunc: "konpeito_color_lime"}
  def self.color_lime: () -> Integer

  %a{cfunc: "konpeito_color_darkgreen"}
  def self.color_darkgreen: () -> Integer

  %a{cfunc: "konpeito_color_darkpurple"}
  def self.color_darkpurple: () -> Integer

  %a{cfunc: "konpeito_color_violet"}
  def self.color_violet: () -> Integer

  %a{cfunc: "konpeito_color_brown"}
  def self.color_brown: () -> Integer

  %a{cfunc: "konpeito_color_darkbrown"}
  def self.color_darkbrown: () -> Integer

  %a{cfunc: "konpeito_color_beige"}
  def self.color_beige: () -> Integer

