  %a{cfunc: "konpeito_color_magenta"}
  def self.color_magenta: () -> Integer

  %a{cfunc: "konpeito_color_blank"}
  def self.color_blank: () -> Integer

  %a{cfunc: "konpeito_color_new"}
  def self.color_new: (Integer r, Integer g, Integer b, Integer a) -> Integer

  %a{cfunc: "konpeito_color_alpha"}
  def self.color_alpha: (Integer color, Float alpha) -> Integer

