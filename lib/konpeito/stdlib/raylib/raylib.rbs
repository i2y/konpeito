# Konpeito stdlib: Raylib bindings
#
# Usage:
#   konpeito build --target mruby game.rb
#   konpeito run --target mruby game.rb
#
# Colors are packed RGBA integers. Use Raylib.color_* methods or
# Raylib.color_new(r, g, b, a) for custom colors.
#
# Key/mouse button constants are accessed via Raylib.key_* / Raylib.mouse_*.

%a{ffi: "raylib"}
module Raylib
  # ── Window Management ──

  %a{cfunc: "konpeito_init_window"}
  def self.init_window: (Integer w, Integer h, String title) -> void

  %a{cfunc: "konpeito_close_window"}
  def self.close_window: () -> void

  %a{cfunc: "konpeito_window_should_close"}
  def self.window_should_close: () -> Integer

  %a{cfunc: "konpeito_set_target_fps"}
  def self.set_target_fps: (Integer fps) -> void

  %a{cfunc: "konpeito_get_frame_time"}
  def self.get_frame_time: () -> Float

  %a{cfunc: "konpeito_get_time"}
  def self.get_time: () -> Float

  %a{cfunc: "konpeito_get_screen_width"}
  def self.get_screen_width: () -> Integer

  %a{cfunc: "konpeito_get_screen_height"}
  def self.get_screen_height: () -> Integer

  %a{cfunc: "konpeito_set_window_title"}
  def self.set_window_title: (String title) -> void

  %a{cfunc: "konpeito_set_window_size"}
  def self.set_window_size: (Integer w, Integer h) -> void

  %a{cfunc: "konpeito_is_window_focused"}
  def self.window_focused?: () -> Integer

  %a{cfunc: "konpeito_is_window_resized"}
  def self.window_resized?: () -> Integer

  %a{cfunc: "konpeito_toggle_fullscreen"}
  def self.toggle_fullscreen: () -> void

  %a{cfunc: "konpeito_get_fps"}
  def self.get_fps: () -> Integer

  # ── Drawing — Core ──

  %a{cfunc: "konpeito_begin_drawing"}
  def self.begin_drawing: () -> void

  %a{cfunc: "konpeito_end_drawing"}
  def self.end_drawing: () -> void

  %a{cfunc: "konpeito_clear_background"}
  def self.clear_background: (Integer color) -> void

  # ── Drawing — Shapes ──

  %a{cfunc: "konpeito_draw_rectangle"}
  def self.draw_rectangle: (Integer x, Integer y, Integer w, Integer h, Integer color) -> void

  %a{cfunc: "konpeito_draw_rectangle_lines"}
  def self.draw_rectangle_lines: (Integer x, Integer y, Integer w, Integer h, Integer color) -> void

  %a{cfunc: "konpeito_draw_circle"}
  def self.draw_circle: (Integer cx, Integer cy, Float radius, Integer color) -> void

  %a{cfunc: "konpeito_draw_circle_lines"}
  def self.draw_circle_lines: (Integer cx, Integer cy, Float radius, Integer color) -> void

  %a{cfunc: "konpeito_draw_line"}
  def self.draw_line: (Integer x1, Integer y1, Integer x2, Integer y2, Integer color) -> void

  %a{cfunc: "konpeito_draw_line_ex"}
  def self.draw_line_ex: (Float x1, Float y1, Float x2, Float y2, Float thick, Integer color) -> void

  %a{cfunc: "konpeito_draw_triangle"}
  def self.draw_triangle: (Float x1, Float y1, Float x2, Float y2, Float x3, Float y3, Integer color) -> void

  %a{cfunc: "konpeito_draw_pixel"}
  def self.draw_pixel: (Integer x, Integer y, Integer color) -> void

  # ── Drawing — Text ──

  %a{cfunc: "konpeito_draw_text"}
  def self.draw_text: (String text, Integer x, Integer y, Integer size, Integer color) -> void

  %a{cfunc: "konpeito_measure_text"}
  def self.measure_text: (String text, Integer size) -> Integer

  # ── Input — Keyboard ──

  %a{cfunc: "konpeito_is_key_down"}
  def self.key_down?: (Integer key) -> Integer

  %a{cfunc: "konpeito_is_key_pressed"}
  def self.key_pressed?: (Integer key) -> Integer

  %a{cfunc: "konpeito_is_key_released"}
  def self.key_released?: (Integer key) -> Integer

  %a{cfunc: "konpeito_is_key_up"}
  def self.key_up?: (Integer key) -> Integer

  %a{cfunc: "konpeito_get_key_pressed"}
  def self.get_key_pressed: () -> Integer

  %a{cfunc: "konpeito_get_char_pressed"}
  def self.get_char_pressed: () -> Integer

  # ── Input — Mouse ──

  %a{cfunc: "konpeito_get_mouse_x"}
  def self.get_mouse_x: () -> Integer

  %a{cfunc: "konpeito_get_mouse_y"}
  def self.get_mouse_y: () -> Integer

  %a{cfunc: "konpeito_is_mouse_button_pressed"}
  def self.mouse_button_pressed?: (Integer btn) -> Integer

  %a{cfunc: "konpeito_is_mouse_button_down"}
  def self.mouse_button_down?: (Integer btn) -> Integer

  %a{cfunc: "konpeito_is_mouse_button_released"}
  def self.mouse_button_released?: (Integer btn) -> Integer

  %a{cfunc: "konpeito_get_mouse_wheel_move"}
  def self.get_mouse_wheel_move: () -> Float

